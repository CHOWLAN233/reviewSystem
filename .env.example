# =============================================================================
# Review Agent – Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control – it contains API keys!

# =============================================================================
# API Keys
# =============================================================================
# Default API key – used for ALL models unless overridden below.
# Set at least this one for single-key convenience.
API_KEY=sk-your-api-key-here

# Optional: per-role API keys (falls back to API_KEY if not set)
# CLASSIFIER_API_KEY=
# SUMMARIZER_API_KEY=
# LAB_SOLVER_API_KEY=

# Optional: custom API base URLs (for proxies / self-hosted / Chinese providers)
# CLASSIFIER_API_BASE=
# SUMMARIZER_API_BASE=
# LAB_SOLVER_API_BASE=

# =============================================================================
# Model Preset
# =============================================================================
# Choose a predefined model combination: budget | balanced | maximum
# Individual model settings below override the preset.
PRESET=balanced

# =============================================================================
# Model Selection (LiteLLM identifiers)
# =============================================================================
# Classifier: cheap, fast model for metadata extraction
# CLASSIFIER_MODEL=gemini/gemini-2.0-flash

# Summarizer: powerful model for deep content generation
# SUMMARIZER_MODEL=claude-sonnet-4-20250514

# Lab Solver: code-capable model (falls back to SUMMARIZER_MODEL if not set)
# LAB_SOLVER_MODEL=claude-sonnet-4-20250514

# =============================================================================
# Model Parameters
# =============================================================================
CLASSIFIER_TEMPERATURE=0.1
CLASSIFIER_MAX_TOKENS=512

SUMMARIZER_TEMPERATURE=0.3
SUMMARIZER_MAX_TOKENS=4096

LAB_SOLVER_TEMPERATURE=0.2
LAB_SOLVER_MAX_TOKENS=4096

# =============================================================================
# Paths (relative to project root, or absolute)
# =============================================================================
INPUT_DIR=01_Input_PPTs
OUTPUT_DIR=02_Output_Notes
STATE_FILE=.sync_state.json

# =============================================================================
# Processing
# =============================================================================
# Number of beginning slides/pages sent to the classifier
CLASSIFICATION_SLIDE_COUNT=3

# Retry settings for LLM API calls
MAX_RETRIES=3
RETRY_BASE_DELAY=2.0

# Secondary review mode: off | basic | deep
#   off   = No post-processing (fastest, may contain artifacts)
#   basic = Regex-based cleanup (recommended, no extra API cost)
#   deep  = Full LLM review pass (most thorough, costs 1 extra API call per file)
REVIEW_MODE=basic

# =============================================================================
# Logging
# =============================================================================
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
